{
  "name": "holoscroll",
  "private": true,
  "version": "1.0.0",
  "description": "全息卷轴 - 个人成长体系化记录与规划工具",
  "author": "HoloScroll Team",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:build-ts": "node scripts/build-electron.cjs",
    "electron:dev": "npm run electron:build-ts && cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run electron:build-ts && electron-builder",
    "electron:build:win": "npm run build && npm run electron:build-ts && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:build-ts && electron-builder --mac",
    "electron:build:linux": "npm run build && npm run electron:build-ts && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.holoscroll.app",
    "productName": "HoloScroll",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HoloScroll"
    },
    "portable": {
      "artifactName": "HoloScroll-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@fluentui/react-charting": "^5.25.7",
    "@fluentui/react-components": "^9.73.7",
    "@fluentui/react-icons": "^2.0.316",
    "@types/d3": "^7.4.3",
    "d3": "^7.9.0",
    "dexie": "^4.4.2",
    "echarts": "^6.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
